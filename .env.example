# API
PORT=4000
NODE_ENV=development
MACRO_STORE_DRIVER=json
MACRO_AUTH_DRIVER=local
MACRO_ALLOW_DEMO_USER=true
MACRO_SEED_DEMO_USER=true
DATABASE_URL=postgresql://macro:macro@localhost:5433/macro
SHADOW_DATABASE_URL=postgresql://macro:macro@localhost:5433/macro_shadow
# Leave blank for deterministic local fallback estimates.
OPENAI_API_KEY=
USDA_API_KEY=
MACRO_AI_PHOTO_MODEL=gpt-5.5
MACRO_AI_TEXT_MODEL=gpt-5.4-mini
MACRO_AI_CORRECTION_MODEL=gpt-5.4-mini
MACRO_AI_BARCODE_UNIT_MODEL=gpt-5.4-mini
MACRO_AI_RATE_LIMIT_WINDOW_MS=3600000
MACRO_AI_TEXT_ESTIMATE_LIMIT=60
MACRO_AI_PHOTO_ESTIMATE_LIMIT=20
MACRO_AI_CORRECTION_LIMIT=60
MACRO_AI_MATCH_SAVED_LIMIT=120
MACRO_AI_DAILY_BUDGET_UNITS=200
MACRO_PHOTO_STORAGE_DRIVER=local
MACRO_PHOTO_DIR=
MACRO_PHOTO_ACCESS_TTL_SECONDS=300
MACRO_PHOTO_MAX_BYTES=8388608
MACRO_PHOTO_REQUEST_BODY_LIMIT_BYTES=12582912
MACRO_RETAINED_PHOTO_RETENTION_DAYS=90

# Supabase Storage. Keep service-role keys API-side only.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
MACRO_SUPABASE_STORAGE_BUCKET=macro-meal-photos

# Optional legacy S3-compatible provider. Not the current default.
MACRO_S3_BUCKET=
MACRO_S3_REGION=us-east-1
MACRO_S3_ENDPOINT=
MACRO_S3_ACCESS_KEY_ID=
MACRO_S3_SECRET_ACCESS_KEY=
MACRO_S3_FORCE_PATH_STYLE=false

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_AUTH_DRIVER=local
EXPO_PUBLIC_ENABLE_DEMO_AUTH=true
EXPO_PUBLIC_ENABLE_PHOTO_RETENTION=true
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
